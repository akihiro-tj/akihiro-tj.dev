---
import { Button } from "@/components/button";
import { Drawer } from "@/components/drawer";
import { SITE_NAME, NAV_ITEMS } from "@/constants";
---

<header class="sticky top-0 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="flex justify-between items-center max-w-5xl mx-auto px-4 py-1">
    <a class="text-xl lg:text-2xl font-semibold" href="/">
      {SITE_NAME}
    </a>
    <ul class="hidden md:flex">
      {NAV_ITEMS.map((item) => (
        <li>
          <a class="block h-full" href={item.url}>
            <Button variant="link">{item.name}</Button>
          </a>
        </li>
      ))}
    </ul>
    <div class="block md:hidden">
      <Drawer client:load />
    </div>
  </div>
</header>
