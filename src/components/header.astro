---
import { AlignRight } from "lucide-react";
import { Button } from "@/components/button";
import { Separator } from "@/components/separator";

const NAV_ITEMS = [
	{ id: "tags", url: "/tags", name: "Tags" },
	{ id: "tags", url: "/tags", name: "Tags" },
];
---

<header>
  <div class="flex justify-between items-center max-w-5xl mx-auto px-4 py-1.5">
    <a class="text-xl font-semibold lg:text-2xl" href="/">
      akihiro-tj.dev
    </a>
    <ul class="hidden md:flex">
      {NAV_ITEMS.map((item) => (
        <li>
          <a class="block h-full" href={item.url}>
            <Button variant="link">{item.name}</Button>
          </a>
        </li>
      ))}
    </ul>
    <div class="block size-5 md:hidden">
      <button type="button">
        <AlignRight className="size-full" />
      </button>
    </div>
  </div>
  <Separator />
</header>
